<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon background layer. Flat brand moss — Material 3 favours solid
  fills over gradients for app icons because launcher masks (circle, squircle,
  teardrop, …) crop unpredictably and gradients can land mid-band after a crop.
  This is a deepened descendant of the in-app MossGo accent (#5A8C58),
  darkened for icon legibility so the cream pin pops without glare. Reads
  like topographic-map ink rather than a stock teal.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#2F5E3A"
        android:pathData="M0,0h108v108h-108z" />
</vector>
