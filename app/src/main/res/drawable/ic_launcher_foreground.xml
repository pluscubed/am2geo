<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground layer.

  Mark: a map pin with a right-pointing arrow cut out of its head — the pin
  reads as "place", the arrow as "send it on", which is exactly what Mapple
  does to an Apple Maps link.

  Geometry: 108×108 canvas, content kept inside the central 66dp safe zone
  (the inscribed circle launcher masks are guaranteed not to crop). The pin
  spans roughly x=39→69, y=29→80, centred at (54, 54); the furthest point
  from centre is the tail tip at distance 26, leaving a 7dp margin under
  the 33dp safe radius. The arrow sits inside the circular head.

  Single path with android:fillType="evenOdd" so the inner arrow subpath
  punches a hole in the pin regardless of subpath winding direction. The
  same geometry is reused verbatim in ic_launcher_monochrome.xml so the
  themed icon is a faithful silhouette of the launcher mark.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="M54,80 L68.72,54.5 A17,17 0 1 0 39.28,54.5 L54,80 Z M44,44 L58,44 L58,40 L64,46 L58,52 L58,48 L44,48 Z" />
</vector>
