<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon background layer. Flat brand teal — Material 3 favours solid
  fills over gradients for app icons because launcher masks (circle, squircle,
  teardrop, …) crop unpredictably and gradients can land mid-band after a crop.
  Colour matches the teal already used in the in-app palette.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#0F766E"
        android:pathData="M0,0h108v108h-108z" />
</vector>
